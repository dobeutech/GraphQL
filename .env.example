# =============================================================================
# Conversation Network Visualization — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# --- Neo4j ---
NEO4J_PASSWORD=changeme
NEO4J_HEAP_MAX=4G
NEO4J_PAGECACHE=2G

# --- Qdrant ---
# Only needed if Qdrant is configured with auth
# QDRANT_API_KEY=

# --- Security ---
JWT_SECRET=changeme-generate-a-random-string

# --- Monitoring (optional — only used with `docker compose --profile monitoring up`) ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --- OpenAI (optional — only if using OpenAI embeddings instead of local model) ---
# OPENAI_API_KEY=
